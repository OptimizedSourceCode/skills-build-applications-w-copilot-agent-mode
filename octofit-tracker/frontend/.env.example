# Vite environment variables for OctoFit Tracker frontend
# Copy this file to .env.local and update values for your environment

# GitHub Codespaces: Set to your Codespace name (e.g., "spacious-space-abc123")
# This enables API calls to: https://${VITE_CODESPACE_NAME}-8000.app.github.dev/api
# Leave empty or unset to use localhost fallback
VITE_CODESPACE_NAME=https://${VITE_CODESPACE_NAME}-8000.app.github.dev/api
VITE_API_URL=http://localhost:8000/api
# Optional: Custom API URL when not using Codespaces
# If VITE_CODESPACE_NAME is set, this is ignored
# Default: http://localhost:8000/api
# VITE_API_URL=http://localhost:8000/api
